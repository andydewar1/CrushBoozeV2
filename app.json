{
  "expo": {
    "name": "CrushBooze",
    "slug": "crushbooze",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "crushbooze",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "CrushBooze is an alcohol cessation app designed for general fitness and wellness purposes only. Not a medical device.",
    "keywords": [
      "quit drinking",
      "alcohol cessation",
      "sobriety",
      "wellness",
      "health tracking",
      "motivation"
    ],
    "category": "health-fitness",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quitdrinking.crushbooze",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera only if you choose to upload a photo or use visual tracking features",
        "ITSAppUsesNonExemptEncryption": false,
        "NSHealthShareUsageDescription": "This app is for general fitness and wellness purposes only and is not a medical device",
        "NSHealthUpdateUsageDescription": "This app is for general fitness and wellness purposes only and is not a medical device",
        "UIBackgroundModes": ["remote-notification"],
        "NSUserNotificationsUsageDescription": "We need to send you notifications about your progress and achievements",
        "NSUserTrackingUsageDescription": "This allows us to measure ad performance and show you more relevant ads"
      },
      "config": {
        "googleMobileAdsAppId": ""
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#35998d"
      },
      "package": "com.quitdrinking.crushbooze",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#35998d",
          "sounds": [],
          "mode": "production",
          "enableBackgroundRemoteNotifications": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "308794b0-e823-46fa-9697-3905d814e2b2"
      },
      "facebookAppId": "1485743649198635",
      "healthDisclaimer": {
        "isHealthApp": true,
        "medicalDevice": false,
        "medicalUse": false,
        "generalFitnessOnly": true,
        "requiresDisclaimer": true,
        "consultHealthcareProvider": true
      }
    }
  }
}
